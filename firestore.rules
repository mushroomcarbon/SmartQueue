rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ──────────────────────────────────────────
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isTA() {
      return isSignedIn() && getUserProfile().role == 'ta';
    }
    
    function sameSchool(schoolId) {
      return isSignedIn() && getUserProfile().schoolId == schoolId;
    }

    // ─── Users Collection ────────────────────────────────────────
    // Users can read their own profile. 
    // Users can create their own profile on registration.
    // No one can modify another user's profile.
    
    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId
        && request.resource.data.keys().hasAll(['uid', 'email', 'displayName', 'role', 'schoolId'])
        && request.resource.data.role in ['student', 'ta']
        && request.resource.data.uid == userId;
      allow update, delete: if false; // profiles are immutable for now
    }

    // ─── Schools Collection ──────────────────────────────────────
    // Anyone signed in can read a school (needed to validate school ID on registration).
    // Only TAs can create schools.
    
    match /schools/{schoolId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if false; // schools are immutable for now
    }

    // ─── Sessions Collection ─────────────────────────────────────
    // Users can read sessions that belong to their school.
    // Only TAs can create/update/delete sessions within their school.
    
    match /sessions/{sessionId} {
      allow read: if isSignedIn() && sameSchool(resource.data.schoolId);
      allow create: if isTA() && sameSchool(request.resource.data.schoolId);
      allow update: if isTA() && sameSchool(resource.data.schoolId);
      allow delete: if isTA() && sameSchool(resource.data.schoolId);

      // ─── Tickets Sub-collection ──────────────────────────────
      // Users in the same school can read tickets.
      // Students can create tickets (with their own uid).
      // TAs can update tickets (resolve, archive). Students can update their own.
      // TAs can delete tickets. Students can delete their own.
      
      match /tickets/{ticketId} {
        allow read: if isSignedIn() && sameSchool(
          get(/databases/$(database)/documents/sessions/$(sessionId)).data.schoolId
        );
        allow create: if isSignedIn() && sameSchool(
          get(/databases/$(database)/documents/sessions/$(sessionId)).data.schoolId
        ) && request.resource.data.uid == request.auth.uid;
        allow update: if isSignedIn() && sameSchool(
          get(/databases/$(database)/documents/sessions/$(sessionId)).data.schoolId
        ) && (isTA() || resource.data.uid == request.auth.uid);
        allow delete: if isSignedIn() && sameSchool(
          get(/databases/$(database)/documents/sessions/$(sessionId)).data.schoolId
        ) && (isTA() || resource.data.uid == request.auth.uid);
      }
    }
  }
}
